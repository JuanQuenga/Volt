{
  "name": "@volt/mobile",
  "private": true,
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm run build:ios",
    "build:ios": "xcodebuild -project ios/Volt.xcodeproj -scheme Volt -configuration Debug -destination 'generic/platform=iOS Simulator' build",
    "build:ios:release": "xcodebuild -project ios/Volt.xcodeproj -scheme Volt -configuration Release -destination 'generic/platform=iOS' build",
    "clean:ios": "xcodebuild -project ios/Volt.xcodeproj -scheme Volt clean",
    "ios": "pnpm run ios:sim",
    "ios:sim": "node scripts/ios-build-install-launch.mjs",
    "ios:sim:release": "node scripts/ios-build-install-launch.mjs --release",
    "ios:device": "node scripts/ios-build-install-launch.mjs --device",
    "ios:device:release": "node scripts/ios-build-install-launch.mjs --device --release",
    "open:xcode": "open ios/Volt.xcodeproj"
  },
  "dependencies": {
    "@expo/ui": "^56.0.18",
    "@expo/vector-icons": "^15.1.1",
    "@hugeicons/core-free-icons": "^4.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-ml-kit/text-recognition": "2.0.0",
    "@volt/scanner-protocol": "workspace:*",
    "base-64": "^1.0.0",
    "expo": "56.0.12",
    "expo-build-properties": "56.0.19",
    "expo-camera": "56.0.8",
    "expo-clipboard": "^56.0.4",
    "expo-constants": "56.0.18",
    "expo-font": "56.0.7",
    "expo-haptics": "^56.0.3",
    "expo-image-manipulator": "^56.0.19",
    "expo-image-picker": "^56.0.18",
    "expo-linking": "^56.0.14",
    "expo-router": "56.2.11",
    "expo-speech-recognition": "56.0.0",
    "expo-status-bar": "^56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-get-random-values": "^1.11.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-webrtc": "^124.0.7",
    "react-native-worklets": "0.8.3"
  }
}
