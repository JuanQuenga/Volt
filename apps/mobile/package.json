{
  "name": "@volt/mobile",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm run build:ios",
    "build:ios": "xcodebuild -workspace ios/Volt.xcworkspace -scheme Volt -configuration Debug -destination 'generic/platform=iOS Simulator' build",
    "build:ios:release": "xcodebuild -workspace ios/Volt.xcworkspace -scheme Volt -configuration Release -destination 'generic/platform=iOS' build",
    "clean:ios": "xcodebuild -workspace ios/Volt.xcworkspace -scheme Volt clean",
    "ios": "pnpm run ios:sim",
    "ios:sim": "node scripts/ios-build-install-launch.mjs",
    "ios:sim:release": "node scripts/ios-build-install-launch.mjs --release",
    "ios:device": "node scripts/ios-build-install-launch.mjs --device",
    "ios:device:release": "node scripts/ios-build-install-launch.mjs --device --release",
    "open:xcode": "open ios/Volt.xcodeproj",
    "test": "node --test tests/*.test.mjs"
  }
}
