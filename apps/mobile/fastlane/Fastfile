require "shellwords"

default_platform(:ios)
opt_out_usage

WORKSPACE = "ios/Volt.xcworkspace"
APP_SCHEME = "Volt"
SCREENSHOT_SCHEME = "VoltScreenshots"
APP_IDENTIFIER = ENV.fetch("VOLT_IOS_BUNDLE_ID", "com.volt.mobile")
TEAM_ID = ENV.fetch("VOLT_APPLE_TEAM_ID", "GB5SPLUARQ")
BUILD_OUTPUT_DIRECTORY = "build/fastlane"

def truthy_env?(name, default = false)
  value = ENV[name]
  return default if value.nil? || value.empty?

  %w[1 true yes on].include?(value.downcase)
end

def app_store_connect_api_key_from_env
  missing = []
  missing << "APP_STORE_CONNECT_API_KEY_ID" unless ENV["APP_STORE_CONNECT_API_KEY_ID"]
  missing << "APP_STORE_CONNECT_ISSUER_ID" unless ENV["APP_STORE_CONNECT_ISSUER_ID"]

  key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
  key_content = ENV["APP_STORE_CONNECT_API_KEY_CONTENT"]
  missing << "APP_STORE_CONNECT_API_KEY_PATH or APP_STORE_CONNECT_API_KEY_CONTENT" unless key_path || key_content

  UI.user_error!("Missing App Store Connect API key environment: #{missing.join(', ')}") unless missing.empty?

  options = {
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
    duration: ENV.fetch("APP_STORE_CONNECT_API_KEY_DURATION", "1200").to_i
  }

  if key_path
    options[:key_filepath] = key_path
  else
    options[:key_content] = key_content
    options[:is_key_content_base64] = truthy_env?("APP_STORE_CONNECT_API_KEY_CONTENT_BASE64")
  end

  app_store_connect_api_key(options)
end

def xcode_auth_xcargs_from_env
  return nil unless ENV["APP_STORE_CONNECT_API_KEY_PATH"] && ENV["APP_STORE_CONNECT_API_KEY_ID"] && ENV["APP_STORE_CONNECT_ISSUER_ID"]

  [
    "-allowProvisioningUpdates",
    "-authenticationKeyPath #{Shellwords.escape(ENV.fetch('APP_STORE_CONNECT_API_KEY_PATH'))}",
    "-authenticationKeyID #{Shellwords.escape(ENV.fetch('APP_STORE_CONNECT_API_KEY_ID'))}",
    "-authenticationKeyIssuerID #{Shellwords.escape(ENV.fetch('APP_STORE_CONNECT_ISSUER_ID'))}"
  ].join(" ")
end

def build_app_store_ipa
  xcode_auth_xcargs = xcode_auth_xcargs_from_env

  build_app(
    workspace: WORKSPACE,
    scheme: APP_SCHEME,
    configuration: "Release",
    clean: true,
    export_method: "app-store",
    output_directory: BUILD_OUTPUT_DIRECTORY,
    output_name: "Volt.ipa",
    export_xcargs: xcode_auth_xcargs,
    export_options: {
      signingStyle: "automatic",
      teamID: TEAM_ID
    }
  )
end

def write_screenshot_report(output_directory)
  output_path = File.expand_path(output_directory, File.expand_path("..", __dir__))
  screenshots = Dir.glob(File.join(output_path, "**", "*.png")).sort
  rows = screenshots.map do |path|
    relative_path = path.delete_prefix("#{output_path}/")
    escaped_path = relative_path.gsub(" ", "%20")
    "<figure><a href=\"#{escaped_path}\"><img src=\"#{escaped_path}\" alt=\"#{File.basename(path)}\"></a><figcaption>#{relative_path}</figcaption></figure>"
  end

  FileUtils.mkdir_p(output_path)
  File.write(
    File.join(output_path, "screenshots.html"),
    <<~HTML
      <!doctype html>
      <html lang="en">
        <head>
          <meta charset="utf-8">
          <meta name="viewport" content="width=device-width, initial-scale=1">
          <title>Volt screenshots</title>
          <style>
            body { margin: 0; padding: 32px; background: #f6f7f8; color: #171717; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
            h1 { margin: 0 0 24px; font-size: 28px; font-weight: 700; }
            .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; align-items: start; }
            figure { margin: 0; padding: 16px; background: white; border: 1px solid #ddd; border-radius: 8px; }
            img { display: block; width: 100%; height: auto; border: 1px solid #eee; }
            figcaption { margin-top: 12px; color: #555; font-size: 13px; overflow-wrap: anywhere; }
          </style>
        </head>
        <body>
          <h1>Volt screenshots</h1>
          <main class="grid">
            #{rows.join("\n        ")}
          </main>
        </body>
      </html>
    HTML
  )
end

def register_frameit_iphone_17_pro_max
  require "frameit"

  return if Frameit::Devices.const_defined?(:IPHONE_17_PRO_MAX)

  Frameit::Devices.const_set(
    :IPHONE_17_PRO_MAX,
    Frameit::Device.new(
      "iphone17-pro-max",
      "Apple iPhone 17 Pro Max",
      14,
      [[1320, 2868], [2868, 1320]],
      460,
      Frameit::Color::SILVER,
      Frameit::Platform::IOS
    )
  )
end

def prepare_rounded_frameit_sources(source_directory, work_directory)
  require "fastimage"

  FileUtils.rm_rf(work_directory)
  FileUtils.mkdir_p(work_directory)

  masks = {}
  screenshot_paths = Dir.glob(File.join(source_directory, "**", "*.png"))
    .reject { |path| path.include?("_framed.png") }
    .sort

  screenshot_paths.each do |source_path|
    relative_path = source_path.delete_prefix("#{source_directory}/")
    destination_path = File.join(work_directory, relative_path)
    FileUtils.mkdir_p(File.dirname(destination_path))
    FileUtils.cp(source_path, destination_path)

    size = FastImage.size(destination_path)
    UI.user_error!("Could not read screenshot dimensions for #{destination_path}") unless size

    width, height = size
    radius = 116
    mask_key = "#{width}x#{height}"
    masks[mask_key] ||= begin
      mask_path = File.join(work_directory, "device_frames", "mask-#{mask_key}.png")
      FileUtils.mkdir_p(File.dirname(mask_path))
      round_rectangle = "roundrectangle 0,0 #{width - 1},#{height - 1} #{radius},#{radius}"
      sh(
        [
          "magick",
          "-size", mask_key,
          "xc:none",
          "-fill", "white",
          "-draw", Shellwords.escape(round_rectangle),
          Shellwords.escape(mask_path)
        ].join(" ")
      )
      mask_path
    end

    masked_path = "#{destination_path}.masked.png"
    sh(
      [
        "magick",
        Shellwords.escape(destination_path),
        "-alpha", "set",
        Shellwords.escape(masks.fetch(mask_key)),
        "-compose", "CopyOpacity",
        "-composite",
        Shellwords.escape(masked_path)
      ].join(" ")
    )
    FileUtils.mv(masked_path, destination_path)
  end
end

def flatten_framed_screenshot(path)
  flattened_path = "#{path}.flattened.png"
  sh(
    [
      "magick",
      Shellwords.escape(path),
      "-background", "white",
      "-alpha", "remove",
      "-alpha", "off",
      Shellwords.escape(flattened_path)
    ].join(" ")
  )
  FileUtils.mv(flattened_path, path)
end

def transparent_framed_path(path)
  path.sub(/_framed\.png\z/, "_framed_transparent.png")
end

platform :ios do
  desc "Validate the local iOS app with the repo-preferred simulator build command"
  lane :build do
    sh("pnpm --filter @volt/mobile build:ios")
  end

  desc "Create a signed App Store IPA with fastlane build_app/gym"
  lane :archive do
    build_app_store_ipa
  end

  desc "Build an App Store IPA and upload it to TestFlight"
  lane :beta do |options|
    api_key = app_store_connect_api_key_from_env
    ipa_path = build_app_store_ipa

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      ipa: ipa_path,
      changelog: options[:changelog] || ENV["TESTFLIGHT_CHANGELOG"],
      skip_waiting_for_build_processing: truthy_env?("FASTLANE_SKIP_WAITING_FOR_BUILD_PROCESSING", true)
    )
  end

  desc "Capture App Store screenshots with the VoltScreenshots UI-test scheme"
  lane :screenshots do
    output_directory = "fastlane/screenshots"

    snapshot(
      workspace: WORKSPACE,
      scheme: SCREENSHOT_SCHEME,
      output_directory: output_directory,
      clear_previous_screenshots: true,
      stop_after_first_error: true,
      clean: true,
      devices: ["iPhone 17 Pro Max"],
      languages: ["en-US"],
      launch_arguments: ["--ui-testing", "--screenshots"]
    )

    write_screenshot_report(output_directory)
  end

  desc "Frame generated screenshots with the iPhone 17 Pro Max device frame"
  lane :frameit_screenshots do
    app_root = File.expand_path("..", __dir__)
    output_directory = File.join(app_root, "fastlane/screenshots")
    frameit_work_directory = File.join(app_root, "build/frameit-screenshots")

    register_frameit_iphone_17_pro_max
    FileUtils.rm_f(Dir.glob(File.join(output_directory, "**", "*_framed*.png")))
    prepare_rounded_frameit_sources(output_directory, frameit_work_directory)

    frame_screenshots(
      path: frameit_work_directory,
      silver: true,
      use_platform: "IOS"
    )

    Dir.glob(File.join(frameit_work_directory, "**", "*_framed.png")).each do |framed_path|
      relative_path = framed_path.delete_prefix("#{frameit_work_directory}/")
      destination_path = File.join(output_directory, relative_path)
      FileUtils.mkdir_p(File.dirname(destination_path))
      FileUtils.cp(framed_path, destination_path)
      FileUtils.cp(framed_path, transparent_framed_path(destination_path))
      flatten_framed_screenshot(destination_path)
    end

    write_screenshot_report(output_directory)
  end
end
