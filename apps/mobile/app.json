{
  "expo": {
    "name": "Volt",
    "slug": "volt-mobile",
    "scheme": "volt",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/volt.icon",
      "bundleIdentifier": "com.volt.mobile",
      "buildNumber": "16",
      "associatedDomains": [
        "applinks:scanner-signal.vercel.app",
        "appclips:scanner-signal.vercel.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Volt uses the camera to scan barcodes, capture photos, model numbers, serial numbers, and other text for the paired Chrome extension.",
        "NSMicrophoneUsageDescription": "Volt uses the microphone for hold-to-speak dictation into the paired Chrome browser.",
        "NSPhotoLibraryUsageDescription": "Volt may request photo library access if an imported image is used for scanning product codes, model numbers, serial numbers, or other text for the paired Chrome extension.",
        "NSSpeechRecognitionUsageDescription": "Volt uses speech recognition to turn dictated speech into text for the paired Chrome browser."
      }
    },
    "android": {
      "package": "com.volt.mobile",
      "icon": "./assets/icon.png",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          }
        }
      ],
      [
        "react-native-app-clip",
        {
          "name": "Volt Clip",
          "bundleIdSuffix": "Clip",
          "targetSuffix": "Clip",
          "deploymentTarget": "16.4",
          "requestEphemeralUserNotification": false,
          "requestLocationConfirmation": false,
          "excludedPackages": [
            "@expo/dom-webview",
            "@expo/log-box",
            "@react-native-ml-kit/text-recognition",
            "@expo/ui",
            "expo-clipboard",
            "expo-camera",
            "expo-dom-webview",
            "expo-file-system",
            "expo-glass-effect",
            "expo-haptics",
            "expo-image-manipulator",
            "expo-keep-awake",
            "expo-speech-recognition",
            "expo-symbols",
            "expo-router",
            "expo-asset",
            "expo-font",
            "expo-linking",
            "@react-native-async-storage/async-storage",
            "@react-native-masked-view/masked-view",
            "react-native-gesture-handler",
            "react-native-get-random-values",
            "react-native-reanimated",
            "react-native-screens",
            "react-native-svg",
            "react-native-webrtc",
            "react-native-worklets"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Volt uses the camera to scan barcodes, capture photos, model numbers, serial numbers, and other text for the paired Chrome extension."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Volt uses the microphone for hold-to-speak dictation into the paired Chrome browser.",
          "speechRecognitionPermission": "Volt uses speech recognition to turn dictated speech into text for the paired Chrome browser."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "reactCompiler": true,
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71dab3bf-43d4-456b-973f-4298fd0b645d"
      }
    },
    "owner": "juanquenga"
  }
}
