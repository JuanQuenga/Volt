{
  "expo": {
    "name": "Volt",
    "slug": "volt-mobile",
    "scheme": "volt",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.volt.mobile",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Volt uses the camera to scan barcodes, model numbers, serial numbers, and other text for the paired Chrome extension."
      }
    },
    "android": {
      "package": "com.volt.mobile",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Volt uses the camera to scan barcodes, model numbers, serial numbers, and other text for the paired Chrome extension."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71dab3bf-43d4-456b-973f-4298fd0b645d"
      }
    },
    "owner": "juanquenga"
  }
}
